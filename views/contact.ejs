<!DOCTYPE html>
<html>
<head>
   <style>
      .contact-content {
        background: rgba(0, 0, 0, 0.95);
        border: none;
        border-left: 8px solid #ff0000;
        color: #ffffff;
        border-radius: 0;
        box-shadow: none;
        max-width: 900px;
        margin: 50px auto 9.3em auto;
        padding: 3em 3em;
        text-align: left;
      }
      .contactform-control, input{
        border-radius: 0;
      }
      .submit-btn {
        background: #ff0000;
        color: #ffffff;
        border: none;
        border-radius: 0;
        padding: 0.8em 2em;
        font-size: 1em;
        font-weight: bold;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: background 0.3s ease;
      }
      .submit-btn:hover {
        background: #cc0000;
      }
      #ContactBody {
        background: url('/images/ContactPagePhoto.jpg') no-repeat center center fixed;
        background-size: cover;
      }   
      .contact-content h3 {
        font-size: 2.5em;
        font-weight: bold;
        color: #ff0000;
        margin-bottom: 1em;
        text-transform: lowercase;
        letter-spacing: 0.02em;
      }
      .contact-content label {
        color: #ffffff;
        display: block;
        font-weight: normal;
        margin-bottom: 0.5em;
        font-size: 0.85em;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .contactform-control {
        padding: 12px 16px;
        font-size: 1.1em;
        border: 2px solid #ff0000;
        border-radius: 0;
        background: #1a1a1a;
        color: #ffffff;
        box-sizing: border-box;
        text-align: left;
        width: 100%;
        max-width: 400px;
        display: block;
        margin: 0.5em 0 1em 0;
      }
     .contactform-control.message-box {
        height: 150px;
        resize: vertical;
        width: 100%;   
        max-width: 100%;
        text-align: left;
     }
     .send-btn {
        background: #ff0000;
        color: #ffffff;
        border: none;
        border-radius: 0;
        padding: 0.8em 2em;
        font-size: 1em;
        font-weight: bold;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: background 0.3s ease;
        margin-top: 1em;
      }
      .send-btn:hover {
        background: #cc0000;
      }
   </style>
    <title>Redhed</title>
    <link rel="stylesheet" href="/css/index.css">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:600&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>

<body class="ContactPage" id="ContactBody">
  <%- include('partials/header') %>

  <div class="contact-content">
    <h3 class="contact-content" centre="middle">Contact Us!</h3>
    <form action="https://formspree.io/f/myzdqvvj" method="POST">    
      <label>
        YOUR NAME
        <input class="contactform-control" type="text" name="name" placeholder="">
      </label>
      <label>
        YOUR EMAIL
        <input class="contactform-control" type="email" name="email" placeholder="">
      </label>
      <div>
        <label>
          YOUR MESSAGE
          <textarea class="contactform-control message-box" name="message" required placeholder=""></textarea>
        </label>
      </div>
      <button class="send-btn" type="submit">SEND</button>
    </form>
  </div>
  
  <%- include('partials/footer') %>
</body>
</html>
