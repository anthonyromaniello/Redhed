<!DOCTYPE html>
<html>
<head>
   <style>
      .contact-content {
        background: rgba(255, 255, 255, 0.85);
        border: 2px solid #FF1744;
        color: #000000;
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.18);
        max-width: 700px;
        margin: 50px auto 9.3em auto;
        padding: 2em 2.5em;
        text-align: center;
      }
      .contactform-control, input{
        border-radius: 0;
      }
      .submit-btn {
        background: #FF1744;
        color: #ffffff;
        border: none;
        border-radius: 12px;
        padding: 0.6em 1.5em;
        font-size: 1.1em;
        cursor: pointer;
        transition: background 0.3s ease;
      }
      .submit-btn:hover {
        background: #ff5252;
      }
      #ContactBody {
        background: url('/images/ContactPagePhoto.jpg') no-repeat center center fixed;
        background-size: cover;
      }   
      .contact-content h3 {
        font-size: 45px;
        font-weight: bold;
        color: #FF1744;
        margin-bottom: 0.5em;
      }
      .contactform-control {
        padding: 12px 16px;
        font-size: 1.1em;
        border: 1.5px solid #ccc;
        border-radius: 8px;
        background: #fafafa;
        box-sizing: border-box;
        text-align: center;
        width: 220px;
        max-width: 100%;
        display: block;
        margin: 0;
      }
     .contactform-control.message-box {
        height: 150px;
        resize: vertical;
        width: 600px;   
        text-align: center;
     }
     .send-btn {
        background: #FF2B2B;
        color: #000000;
        border: none;
        border-radius: 12px;
        padding: 0.6em 1.5em;
        font-size: 1.1em;
        cursor: pointer;
        transition: background 0.3s ease;
      }
      .send-btn:hover {
        background: #e60000;
      }
   </style>
    <title>Redhed</title>
    <link rel="stylesheet" href="/css/index.css">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:600&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>

<body class="ContactPage" id="ContactBody">
  <%- include('partials/header') %>

  <div class="contact-content">
    <h3 class="contact-content">Contact Us!</h3>
    <form action="https://formspree.io/f/myzdqvvj" method="POST">    
      <label>
        Your name:
        <input class="contactform-control" type="text" name="name">
      </label>
      <label>
        Your email:
        <input class="contactform-control" type="email" name="email">
      </label>
      <div>
        <label>
          Your message:
          <textarea class="contactform-control message-box" name="message" required></textarea>
        </label>
      </div>
      <button class="send-btn" type="submit">Send</button>
    </form>
  </div>
  
  <%- include('partials/footer') %>
</body>
</html>
