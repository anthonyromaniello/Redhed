<!DOCTYPE html>
<html lang="en">
<head>
    <title>Redhed</title>
    <link rel="stylesheet" href="/css/index.css">
    <style>
        .welcome-section {
            background: #fff;
            color: #000;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.18);
            max-width: 800px;
            margin: 8em auto 19.1em auto;
            padding: 2em 2.5em;
            text-align: center;
        }
        .welcome-heading {
            font-size: 2em;
            font-weight: bold;
            margin-bottom: 1em;
            color: #FF2B2B;
        }
        .welcome-overview {
            font-size: 1.15em;
            color: #000;
            line-height: 1.6;
            margin-bottom: 0;
        }
        .view-more-btn {
            background: #FF2B2B;
            color: #000000;
            border: none;
            border-radius: 12px;
            padding: 0.6em 1.5em;
            font-size: 1.1em;
            cursor: pointer;
            transition: background 0.3s ease;
        }
        .view-more-btn:hover {
            background: #e60000;
        }
        .founders-container {
            display: flex;
            gap: 2em;
            margin-top: 2em;
            margin-bottom: 3em;
            align-items: flex-start;
            justify-content: center;
            flex-wrap: wrap;
        }
        .founderCard {
            background: rgba(255, 255, 255, 0.85);
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.18);
            padding: 2em 1em;
            align-items: center;
            display: flex;
            flex-direction: column;
            width: auto;
            margin: 1em 0;
        }
        .founder-name {
            color: #FF2B2B;
            font-size: 1.3em;
            font-weight: bold;
            margin-bottom: 0.2em;
            text-align: center;
        }
        .founder-title {
            color: #000;
            font-size: 1.05em;
            font-style: italic;
            margin-bottom: 0.7em;
            text-align: center;
        }
        .founderCard img {
            width: auto;
            height: auto;
            max-width: 100%;
            max-height: 300px;
            margin-bottom: 1em;
        }
    </style>
    <link href="https://fonts.googleapis.com/css?family=Montserrat:600&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>

<body>
    <%- include('partials/header') %>

    <div class="welcome-section">
        <h2 class="welcome-heading">Welcome to RedHed</h2>
        <p class="welcome-overview">
            Redhed is an indie band based out of Vaughan, Ontario.<br><br>
            Blending elements of rock, indie, and punk, Redhed aims to fill the absence of local bands, venues, or role models in the suburbs <br><br>
            <span style="color:red">Redhed</span> isn't just a band, but an answer to that silence.
        </p>
        <br><button class="view-more-btn" onclick="window.location.href='/news'">View More</button>
    </div>

    <div class="founders-container">
        <div class="founderCard">
            <img class="founder-img" src="/images/Anthony.JPEG" alt="Anthony Romaniello">
            <div class="founder-name">Anthony Romaniello</div>
            <div class="founder-title">Lead Guitarist</div>
        </div>
        <div class="founderCard">
            <img class="founder-img" src="/images/Triss.jpg" alt="Triss Raggiunti">
            <div class="founder-name">Triss Raggiunti</div>
            <div class="founder-title">Lead Vocalist</div>
        </div>
        <div class="founderCard">
            <img class="founder-img" src="/images/Jack.JPEG" alt="Jack Kirwan">
            <div class="founder-name">Jack Kirwan</div>
            <div class="founder-title">Rythym Guitarist</div>
        </div>
        <div class="founderCard">
            <img class="founder-img" src="/images/Jaylan.JPEG" alt="Jaylan Morley">
            <div class="founder-name">Jaylan Morley</div>
            <div class="founder-title">Bassist</div>
        </div>
        <div class="founderCard">
            <img class="founder-img" src="/images/Arrigo.JPEG" alt="Anthony Arrigo">
            <div class="founder-name">Anthony Arrigo</div>
            <div class="founder-title">Drummer</div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.min.js" integrity="sha384-w1Q4orYjBQndcko6MimVbzY0tgp4pWB4lZ7lr30WKz0vr/aWKhXdBNmNb5D92v7s" crossorigin="anonymous"></script>
    
    <%- include('partials/footer') %>
</body>
</html>
