<!DOCTYPE html>
<html>
<head>
    <title>Redhed</title>
    <link rel="stylesheet" href="/css/index.css">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:600&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        .services-icons-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2em;
            max-width: 1100px;
            margin: 3em auto 2em auto;
            padding: 0 2em;
        }
        .service-icon-block {
            display: flex;
            flex-direction: column;
            background: rgba(0, 0, 0, 0.95);
            border: none;
            border-left: 6px solid #ff0000;
            border-radius: 0;
            padding: 2em 2em;
            box-shadow: none;
        }
        .service-button {
            color: #ffffff;
            background: #ff0000;
            font-size: 1em;
            font-weight: bold;
            text-align: center;
            margin-top: 1em;
            padding: 0.8em 1.5em;
            border-radius: 0;
            box-shadow: none;
            display: inline-block;
            transition: background 0.3s ease;
            border: none;
            /**
            cursor: pointer;
            */
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        /**
        .service-button:hover{
            background: #cc0000;
        }  
        */
         
        .services-header-section {
            background: rgba(0, 0, 0, 0.95);
            color: #ffffff;
            border: none;
            border-left: 8px solid #ff0000;
            border-radius: 0;
            box-shadow: none;
            max-width: 900px;
            margin: 2.5em auto 2em auto;
            padding: 3em 3em;
            text-align: left;
        }
        .services-header-title {
            font-size: 2.5em;
            font-weight: bold;
            margin-bottom: 0.8em;
            color: #ff0000;
            text-transform: lowercase;
            letter-spacing: 0.02em;
        }
        .services-header-overview {
            font-size: 1.15em;
            color: #ffffff;
            margin-bottom: 0;
            line-height: 1.8;
        }
    </style>
</head>

<body class="backgroundGradient">
    <%- include('partials/header') %>
    
    <div class="services-header-section">
        <h2 class="services-header-title">redhed merchandise</h2>
        <p class="services-header-overview">
        Check out our merchandise below, which we sell exclusively during our shows. Here you'll find items including band t-shirts, hoodies, Accessories, and more. Each purchase helps us continue making music and bringing you performances to remember! Showing your support means the world to us!
        </p>
    </div>

    <div class="services-icons-container">
        <div class="service-icon-block">
            <img src="/images/BlackTee.png" alt="Custom Builds Icon" style="width: 400px; height: 400px; margin-bottom:0.7em;">
            <div class="service-button" style="width: 400px">Black Tee - $20</div>
            <p style="text-align: center; color: white;"> out of stock :&#40</p>
        </div>
        <div class="service-icon-block">
            <img src="/images/WhoAreWeTee.png" alt="Custom Builds Icon" style="width: 400px; height: 400px; margin-bottom:0.7em;">
            <div class="service-button" style="width: 400px">"Who Are We" tee - $20</div>
        </div>
    </div>

    <script>
        //add "onclick="reserveMerch(1, 101)" to button style if backend for reservation is ever needed
        function reserveMerch(customerId, merchId) {
            fetch('/reserve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ customerId, merchId })
            })
            .then(res => res.json())
            .then(data => alert(data.message))
            .catch(err => alert('Error: ' + err));
        }
    </script>
    
    <%- include('partials/footer') %>
</body>
</html>
