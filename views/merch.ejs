<!DOCTYPE html>
<html>
<head>
    <title>Redhed</title>
    <link rel="stylesheet" href="/css/index.css">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:600&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        .services-icons-container {
            display: flex;                
            justify-content: center;      
            gap: 2em;                     
            margin: 3em auto 2em auto;    
            flex-wrap: wrap;              
        }
        .service-icon-block {
            display: flex;                
            flex-direction: column;
            align-items: center;
            background: #fff;
            border-radius: 14px;         
            padding: 1.5em 1em;         
            box-shadow: 0 4px 16px rgba(0,0,0,0.10); 
            min-width: 120px;             
            margin: 1em 0;         
        }
        .service-button {
            color: #fff;
            background: #e63946;
            font-size: 1.3em;
            font-weight: bold;
            text-align: center;
            margin-top: 0.7em;
            padding: 0.5em 1em;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.10);
            display: inline-block;
            transition: background 0.3s ease;
            border: none;
            cursor: pointer;
        }
        .service-button:hover{
            background: #b71c1c; 
        }   
        .services-header-section {
            background: #e63946;
            color: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.10);
            max-width: 700px;
            margin: 2.5em auto 2em auto;
            padding: 2.2em 2em;
            text-align: center;
        }
        .services-header-title {
            font-size: 2em;
            font-weight: bold;
            margin-bottom: 0.7em;
            color: #fff;
        }
        .services-header-overview {
            font-size: 1.15em;
            color: #fffbe6;
            margin-bottom: 0;
        }
    </style>
</head>

<body class="backgroundGradient">
    <%- include('partials/header') %>
    
    <div class="services-header-section">
        <h2 class="services-header-title"><span style="color:#6b1414">Redhed</span> Merchandise</h2>
        <p class="services-header-overview">
        Check out our merchandise below, which we sell exclusively during our shows. Here you'll find items including band t-shirts, hoodies, posters, and more. Each purchase helps us continue making music and bringing you great shows. Showing your support means the world to us!
        </p>
    </div>

    <div class="services-icons-container">
        <div class="service-icon-block">
            <img src="/images/BlackTee.png" alt="Custom Builds Icon" style="width: 400px; height: 400px; margin-bottom:0.7em;">
            <button class="service-button" onclick="reserveMerch(1, 101)">Black Tee - $20</button>
        </div>
    </div>

    <script>
        function reserveMerch(customerId, merchId) {
            fetch('/reserve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ customerId, merchId })
            })
            .then(res => res.json())
            .then(data => alert(data.message))
            .catch(err => alert('Error: ' + err));
        }
    </script>
    
    <%- include('partials/footer') %>
</body>
</html>
