<!DOCTYPE html>
<html>
<head>
    <title>Redhed</title>
    <script src="/js/Scripts.js"></script>
    <style>
        .Blog-section {
            background: rgba(0, 0, 0, 0.95);
            color: #ffffff;
            border-radius: 0;
            box-shadow: none;
            max-width: 900px;
            margin: 8em auto 2em auto;
            padding: 3em 3em;
            text-align: left;
            border-left: 8px solid #ff0000;
        }
        .Blog-title {
            font-size: 2.5em;
            font-weight: bold;
            margin-bottom: 0.8em;
            color: #ff0000;
            text-transform: lowercase;
            letter-spacing: 0.02em;
        }
        .Blog-item {
            font-size: 1.15em;
            color: #ffffff;
            line-height: 1.8;
            margin-bottom: 0;
        }
        .blog-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 2em;
            background: transparent;
            color: #ffffff;
        }
        .blog-header {
            text-align: left;
            margin-bottom: 3em;
            padding: 3em 3em;
            background: rgba(0, 0, 0, 0.95);
            color: #ffffff;
            border-radius: 0;
            border-left: 8px solid #ff0000;
            box-shadow: none;
        }
        .blog-header h1 {
            font-size: 3em;
            color: #ff0000;
            margin-bottom: 0.5em;
            text-transform: lowercase;
            letter-spacing: 0.02em;
        }
        .blog-header p {
            font-size: 1.2em;
            color: #ffffff;
        }
        .blog-post {
            background: rgba(0, 0, 0, 0.95);
            color: #ffffff;
            border-radius: 0;
            box-shadow: none;
            margin-bottom: 2.5em;
            padding: 3em 3em;
            border-left: 6px solid #ff0000;
        }
        .blog-post-title {
            font-size: 2.2em;
            font-weight: bold;
            margin-bottom: 0.5em;
            color: #ff0000;
            text-transform: lowercase;
            letter-spacing: 0.02em;
        }
        .blog-post-meta {
            font-size: 0.9em;
            color: #cccccc;
            margin-bottom: 1.5em;
            border-bottom: 2px solid #ff0000;
            padding-bottom: 1em;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .blog-post-content {
            font-size: 1.1em;
            color: #ffffff;
            line-height: 1.8;
        }
        .blog-post-content h3 {
            color: #ff0000;
            margin: 1.5em 0 1em 0;
            text-transform: lowercase;
        }
        .read-more {
            display: inline-block;
            margin-top: 1em;
            color: #ffffff;
            text-decoration: none;
            font-weight: bold;
            border: 2px solid #ff0000;
            padding: 0.7em 1.5em;
            border-radius: 0;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        .read-more:hover {
            background: #ff0000;
            color: #000000;
        }
        @media (max-width: 768px) {
            .blog-container {
                padding: 1em;
            }
            .blog-header h1 {
                font-size: 2.2em;
            }
            .blog-post {
                padding: 1.5em;
            }
            .blog-post-title {
                font-size: 1.8em;
            }
        }
    </style>
    <link rel="stylesheet" href="/css/index.css">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:600&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body class="backgroundGradient">
    <%- include('partials/header') %>

    <div class="blog-container" id="blog-list">
        <div class="blog-header">
            <h1>latest news and updates</h1>
            <p>Stay up to date with, releases, announcements, and more.</p>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.min.js" integrity="sha384-w1Q4orYjBQndcko6MimVbzY0tgp4pWB4lZ7lr30WKz0vr/aWKhXdBNmNb5D92v7s" crossorigin="anonymous"></script>
    
    <%- include('partials/footer') %>
</body>
</html>
