<!DOCTYPE html>
<html>
<head>
    <title>Redhed</title>
    <script src="/js/Scripts.js"></script>
    <style>
        .Blog-section {
            background: #fff;
            color: #000000;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.18);
            max-width: 800px;
            margin: 8em auto 2em auto;
            padding: 3.14em 2.5em;
            text-align: center;
        }
        .Blog-title {
            font-size: 2em;
            font-weight: bold;
            margin-bottom: 1em;
            color: #000;
        }
        .Blog-item {
            font-size: 1.15em;
            color: #000;
            line-height: 1.6;
            margin-bottom: 0;
        }
        .blog-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 2em;
            background: rgba(255, 255, 255, 0.9);
            color: #000000;
        }
        .blog-header {
            text-align: center;
            margin-bottom: 3em;
            padding: 2em 0;
            background: rgba(255, 255, 255, 0.9);
            color: #000;
        }
        .blog-header h1 {
            font-size: 3em;
            color: #000;
            margin-bottom: 0.5em;
        }
        .blog-header p {
            font-size: 1.2em;
            color: #000;
        }
        .blog-post {
            background: #fff;
            color: #000;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.18);
            margin-bottom: 2.5em;
            padding: 2.5em;
            border-left: 5px solid #e00000;
        }
        .blog-post-title {
            font-size: 2.2em;
            font-weight: bold;
            margin-bottom: 0.5em;
            color: #000;
        }
        .blog-post-meta {
            font-size: 0.9em;
            color: #000;
            margin-bottom: 1.5em;
            border-bottom: 1px solid #444;
            padding-bottom: 1em;
        }
        .blog-post-content {
            font-size: 1.1em;
            color: #000;
            line-height: 1.8;
        }
        .blog-post-content h3 {
            color: #000;
            margin: 1.5em 0 1em 0;
        }
        .read-more {
            display: inline-block;
            margin-top: 1em;
            color: #000;
            text-decoration: none;
            font-weight: bold;
            border: 2px solid #000;
            padding: 0.5em 1em;
            border-radius: 5px;
            transition: all 0.3s ease;
        }
        .read-more:hover {
            background: #000;
            color: #fff;
        }
        @media (max-width: 768px) {
            .blog-container {
                padding: 1em;
            }
            .blog-header h1 {
                font-size: 2.2em;
            }
            .blog-post {
                padding: 1.5em;
            }
            .blog-post-title {
                font-size: 1.8em;
            }
        }
    </style>
    <link rel="stylesheet" href="/css/index.css">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:600&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body class="backgroundGradient">
    <%- include('partials/header') %>

    <div class="blog-container" id="blog-list">
        <div class="blog-header">
            <h1>Latest News and Updates</h1>
            <p>Stay up to date with future show dates, releases, and more.</p>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.min.js" integrity="sha384-w1Q4orYjBQndcko6MimVbzY0tgp4pWB4lZ7lr30WKz0vr/aWKhXdBNmNb5D92v7s" crossorigin="anonymous"></script>
    
    <%- include('partials/footer') %>
</body>
</html>
